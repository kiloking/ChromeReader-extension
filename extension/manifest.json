{
  "manifest_version": 3,
  "name": "MiniMax 文章側欄總結",
  "version": "0.1.0",
  "description": "瀏覽文章時於側欄一鍵擷取正文並以 MiniMax 產生重點與靈感片段。",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "開啟 MiniMax 總結側欄",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "permissions": ["storage", "sidePanel", "scripting", "activeTab", "tabs"],
  "host_permissions": [
    "https://*/*",
    "http://*/*"
  ]
}
